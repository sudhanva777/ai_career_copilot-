# Backend environment — loaded when uvicorn runs from the backend/ directory
# Generated SECRET_KEY (64-char hex, 256-bit entropy)
SECRET_KEY=eee23032b2bcaf494de5b0ea9670d5abaf66c80517ae14d855a445526b9b168c

# Database — SQLite for local dev, switch to Postgres URL for production
DATABASE_URL=sqlite:///./app.db

# Set to development so cookies work over plain HTTP locally
# Change to production when deploying behind HTTPS
ENVIRONMENT=development

# Ollama local endpoint
OLLAMA_BASE_URL=http://localhost:11434

# Upload directory
UPLOAD_DIR=./uploads

# CORS — include both Vite dev port (5173) and CRA/production port (3000)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
